@model List<vroom.Models.Motorcycle>

@{
    ViewData["Title"] = "ადმინი - მოტოციკლები";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">&#x1F3CD;&#xFE0F; მოტოციკლების მართვა</h1>
        <a href="@Url.Action("CreateMotorcycle", "Admin")" class="btn btn-primary">+ ახალი მოტოციკლი</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>სურათი</th>
                        <th>მარკა / მოდელი</th>
                        <th>წელი</th>
                        <th>კატეგორია</th>
                        <th>ფასი</th>
                        <th>ძრავა</th>
                        <th class="text-end">მოქმედება</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bike in Model)
                    {
                        <tr>
                            <td>
                                <img src="@bike.ImageUrl" alt="@bike.Make @bike.Model"
                                     style="width:80px;height:55px;object-fit:cover;border-radius:6px;" />
                            </td>
                            <td><strong>@bike.Make</strong> @bike.Model</td>
                            <td>@bike.Year</td>
                            <td><span class="badge bg-secondary">@bike.Category</span></td>
                            <td>&#x20BE;@bike.Price.ToString("F0")</td>
                            <td class="text-muted small">@bike.Engine</td>
                            <td class="text-end">
                                <a href="@Url.Action("EditMotorcycle", "Admin", new { id = bike.Id })"
                                   class="btn btn-sm btn-outline-primary me-1">&#x270F; რედაქტირება</a>
                                <form method="post" action="@Url.Action("DeleteMotorcycle", "Admin", new { id = bike.Id })"
                                      class="d-inline"
                                      onsubmit="return confirm('@bike.Make @bike.Model - წაშლა დაადასტურეთ')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">&#x1F5D1; წაშლა</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">მოტოციკლები არ მოიძებნა</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">&larr; დაშბორდი</a>
    </div>
</div>
