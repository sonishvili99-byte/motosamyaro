@model vroom.Models.Motorcycle

@{
    var isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "მოტოციკლის რედაქტირება" : "ახალი მოტოციკლი";
    var formAction = isEdit
        ? Url.Action("EditMotorcycle", "Admin", new { id = Model.Id })
        : Url.Action("CreateMotorcycle", "Admin");
    var categories = new[] { "კრუიზერი", "სპორტი", "ენდურო", "ბობერი", "სტრიტი" };
    var galleryRaw = ViewBag.GalleryImagesRaw as string ?? string.Join("\n", Model.GalleryImages ?? new List<string>());
}

<div class="container mt-4" style="max-width:780px;">
    <h1 class="mb-4">@ViewData["Title"]</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="card p-4">
        <form method="post" action="@formAction">
            @Html.AntiForgeryToken()
            @if (isEdit)
            {
                <input type="hidden" name="Id" value="@Model.Id" />
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">მარკა *</label>
                    <input type="text" name="Make" value="@Model.Make" class="form-control" placeholder="Yamaha" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">მოდელი *</label>
                    <input type="text" name="Model" value="@Model.Model" class="form-control" placeholder="MT-03" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">წელი *</label>
                    <input type="number" name="Year" value="@(Model.Year == 0 ? DateTime.Now.Year : Model.Year)"
                           class="form-control" min="1900" max="2100" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">კატეგორია *</label>
                    <select name="Category" class="form-select" required>
                        <option value="">-- აირჩიეთ --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat" selected="@(Model.Category == cat ? "selected" : null)">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">ფასი (&#x20BE;) *</label>
                    <input type="number" name="Price" value="@(Model.Price == 0 ? "" : Model.Price.ToString("F2"))"
                           class="form-control" step="0.01" min="0" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-bold">მთავარი სურათის URL *</label>
                    <input type="url" name="ImageUrl" value="@Model.ImageUrl" class="form-control"
                           placeholder="https://example.com/bike.jpg" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">ძრავა *</label>
                    <input type="text" name="Engine" value="@Model.Engine" class="form-control" placeholder="321cc Parallel Twin" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">ცხენისძალა *</label>
                    <input type="text" name="Horsepower" value="@Model.Horsepower" class="form-control" placeholder="41.7 HP / 31.1 kW" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">თორქი *</label>
                    <input type="text" name="Torque" value="@Model.Torque" class="form-control" placeholder="41.2 Nm" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">საწვავის ავზი *</label>
                    <input type="text" name="FuelCapacity" value="@Model.FuelCapacity" class="form-control" placeholder="14.8 L" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">მაქს. სიჩქარე *</label>
                    <input type="text" name="TopSpeed" value="@Model.TopSpeed" class="form-control" placeholder="209 km/h" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-bold">გალერეის სურათები</label>
                    <textarea name="galleryImagesRaw" class="form-control" rows="4"
                              placeholder="&#x10d7;&#x10d8;&#x10d7;&#x10dd; URL &#x10d0;&#x10ee;&#x10d0;&#x10da; &#x10e1;&#x10e2;&#x10e0;&#x10d8;&#x10e5;&#x10dd;&#x10dc;&#x10d6;&#x10d4;">@galleryRaw</textarea>
                    <div class="form-text">თითო URL ახალ სტრიქონზე (არასავალდებულო)</div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    @(isEdit ? "შენახვა" : "დამატება")
                </button>
                <a href="@Url.Action("Motorcycles", "Admin")" class="btn btn-secondary">გაუქმება</a>
            </div>
        </form>
    </div>
</div>
