<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="ka" />
    <title>@ViewData["Title"] - VRoom</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-gradient mb-0">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">მოტო სამყარო</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">მთავარი</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Gallery">გალერეა</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">ჩვენს შესახებ</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Dashboard">⚙️ ადმინი</a>
                            </li>
                        }
                    </ul>
                    <form class="navbar-search-form d-flex me-3" asp-area="" asp-controller="Home" asp-action="Search">
                        <input class="form-control me-2" type="search" placeholder="ეძებეთ..." aria-label="Search" name="query">
                        <button class="btn btn-outline-light" type="submit">ძებნა</button>
                    </form>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Cart" asp-action="Index">🛒 კალათა</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">პროფილი</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-area="" asp-controller="Account" asp-action="Logout" class="d-inline">
                                            <button type="submit" class="dropdown-item">გამოსვლა</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">🔐 შესვლა</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Register">📝 რეგისტრაცია</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="site-page">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - მოტო სამყარო - <a asp-area="" asp-controller="Home" asp-action="About">ჩვენს შესახებ</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Toast container -->
    <div id="toastContainer"></div>

    <!-- Scroll to top button -->
    <button id="scrollTopBtn" aria-label="Scroll to top">&#8679;</button>

    <!-- Test Ride Modal (Sidebar) -->
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="modal fade" id="testRideModalSidebar" tabindex="-1" aria-labelledby="testRideModalSidebarLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="testRideModalSidebarLabel">მოტოციკლის გატესტვა</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="post" action="@Url.Action("BookTestRide", "TestRide")" id="testRideFormSidebar">
                        @Html.AntiForgeryToken()
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="phoneNumberSidebar" class="form-label">ტელეფონის ნომერი *</label>
                                <input type="tel" class="form-control" id="phoneNumberSidebar" name="phoneNumber" placeholder="+995 5XX XXX XXX" required />
                                <small class="form-text text-muted">გთხოვთ შეიყვანეთ ტელეფონის ნომერი. ჩვენი სპეციალისტი დაგიკავშირდებათ ამ ნომერზე.</small>
                            </div>
                            <div class="alert alert-info">
                                <h6 class="alert-heading">📋 შეკვეთის პირობები</h6>
                                <small>
                                    <p>თქვენი მოთხოვნის შემდეგ, ჩვენი სპეციალისტი დაგიკავშირდებათ ტელეფონის ნომერზე, რათა:</p>
                                    <ul class="mb-0">
                                        <li>დაზუსტოს თქვენი საჭიროებები და პირადი პრეფერენციები</li>
                                        <li>მოამზადოს დეტალური ინფორმაცია ხელმისაწვდომ მოტოციკლებზე</li>
                                        <li>შეთანხმოს თავისუფალი დღე და დრო ტესტ რაიდისთვის</li>
                                    </ul>
                                </small>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="agreeTermsSidebar" name="agreeTerms" required />
                                <label class="form-check-label" for="agreeTermsSidebar">
                                    ✓ ვეთანხმები პირობებს
                                </label>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">გაუქმება</button>
                            <button type="submit" class="btn btn-primary">დაჯავშვნა</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

</body>
</html>



