@model List<vroom.Models.Motorcycle>

@{
    ViewData["Title"] = "მოტოციკლების გალერეა";
    string galleryTitle = "მოტოციკლების გალერეა";
    string emptyMessage = "სამწუხაროდ!";
    string emptyDetail = "ამჟამად მოტოციკლი მარაგში არ გვაქვს. გთხოვთ მოგვიანებით შეამოწმეთ.";
    
    var motorcycles = Model ?? new();
}

<style>
    .gallery-hero {
        position: relative;
        background-size: cover;
        background-position: center;
        padding: 4rem 0;
        min-height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .gallery-title-box {
        background: white;
        padding: 2rem 3rem;
        border-radius: 1rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .gallery-title {
        font-weight: 700;
        color: #667eea;
        font-size: 3rem;
        margin: 0;
        text-shadow: none;
    }

    .gallery-container {
        padding: 3rem 0;
    }

    .motorcycle-section {
        margin-bottom: 4rem;
    }

    .motorcycle-name {
        font-size: 1.75rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 3px solid #667eea;
    }

    .motorcycle-gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .gallery-image-card {
        position: relative;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: none;
        transition: all 0.3s ease;
        background: #f5f5f5;
        aspect-ratio: 4/3;
    }

    .gallery-image-card:hover {
        transform: scale(1.02);
        box-shadow: none;
    }

    .gallery-image-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    @@media (max-width: 768px) {
        .gallery-title {
            font-size: 2rem;
        }

        .motorcycle-name {
            font-size: 1.25rem;
        }

        .motorcycle-gallery-grid {
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1rem;
        }
    }
</style>

<div class="gallery-hero">
    <div class="gallery-title-box">
        <h1 class="gallery-title">@galleryTitle</h1>
    </div>
</div>

<div class="gallery-container">
    <div class="container">
        @if (motorcycles.Count > 0)
        {
            @foreach (var bike in motorcycles)
            {
                <div class="motorcycle-section">
                    <h2 class="motorcycle-name">@bike.Make @bike.Model (@bike.Year)</h2>
                    <div class="motorcycle-gallery-grid">
                        @if (bike.GalleryImages != null && bike.GalleryImages.Count > 0)
                        {
                            @foreach (var imageUrl in bike.GalleryImages)
                            {
                                <div class="gallery-image-card">
                                    <img src="@imageUrl" alt="@bike.Make @bike.Model" loading="lazy">
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info" role="alert">
                <strong>@emptyMessage</strong> @emptyDetail
            </div>
        }
    </div>
</div>



