@{
    ViewData["Title"] = "ჩვენს შესახებ";
}

<div class="container mt-5">
    <h1 class="mb-5">@ViewData["Title"]</h1>

    <div class="row mb-5">
        <div class="col-lg-8 reveal-left">
            <p class="lead mb-3">მოტო სამყარო არის საქართველოს წამყვანი მოტოციკლების ონლაინ მარკეტი, ჩვენთან იპოვით პროფესიონალურ მომსახურებას და ყველაზე მოთხოვნად მოტოებს მისაღებ ფასად</p>
            
            <p>2010 წლიდან, მოტო სამყარო თავსდება მოტოციკლეტის კულტურაში, პრემიუმ ბრენდებთან პარტნიორობით და უდროო მომსახურებით. ჩვენი მიზანი უბრალოა: თითოეულმა ადამიანმა იპოვოს მისი ოცნების მოტოციკლი,ექსპერტიზით და ტრენინგით. დღეს ჩვენ ერთ-ერთი ყველაზე სანდო მოტოციკლების რეტეილერი ვართ რეგიონში, მსოფლიოს კლასის პროდუქტებით.</p>
        </div>
        <div class="col-lg-4 reveal-right">
            <div class="card border-primary h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">მოტოციკლის გატესტვა</h5>
                    <p class="card-text">გსურთ რეალურად ის იცხოვროთ? დაჯავშვნეთ თქვენი ტესტ-დრაივ დღეს!</p>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <button class="btn btn-primary w-100 btn-cta-pulse" data-bs-toggle="modal" data-bs-target="#testRideModal">დაჯავშვნა</button>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary w-100 btn-cta-pulse">შემოსვლა და დაჯავშვნა</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="section-divider"></div>

    <h2 class="mb-4 mt-5">რატომ აირჩიოთ "მოტო სამყარო"?</h2>
    <div class="features-section">
        <div class="feature-card reveal">
            <div class="feature-icon">✓</div>
            <h4 class="feature-title">ხარისხი</h4>
            <p class="feature-text">აღჭურვილი საუკეთესო მოტოციკლებით</p>
        </div>
        <div class="feature-card reveal" style="transition-delay:0.1s">
            <div class="feature-icon">🚀</div>
            <h4 class="feature-title">სწრაფი</h4>
            <p class="feature-text">ხელმისაწვდომი და სწრაფი სერვისი!</p>
        </div>
        <div class="feature-card reveal" style="transition-delay:0.2s">
            <div class="feature-icon">💼</div>
            <h4 class="feature-title">პროფესიონალური</h4>
            <p class="feature-text">გამოცდილი კონსულტანტები</p>
        </div>
        <div class="feature-card reveal" style="transition-delay:0.3s">
            <div class="feature-icon">🛡️</div>
            <h4 class="feature-title">უსაფრთხოება</h4>
            <p class="feature-text">დაცული ყიდვა-გაყიდვის პროცესი</p>
        </div>
    </div>

    <div class="section-divider"></div>

    <h2 class="mb-4 mt-5">სტატისტიკა</h2>
    <div class="stats-grid">
        <div class="stat-box reveal">
            <div class="stat-number" data-target="500" data-suffix="+">0</div>
            <div class="stat-label">მოტოციკლი</div>
        </div>
        <div class="stat-box reveal" style="transition-delay:0.1s">
            <div class="stat-number" data-target="2000" data-suffix="+">0</div>
            <div class="stat-label">კმაყოფილი მყიდველი</div>
        </div>
        <div class="stat-box reveal" style="transition-delay:0.2s">
            <div class="stat-number" data-target="15" data-suffix="+">0</div>
            <div class="stat-label">წლის გამოცდილება</div>
        </div>
        <div class="stat-box reveal" style="transition-delay:0.3s">
            <div class="stat-number">24/7</div>
            <div class="stat-label">დახმარება</div>
        </div>
    </div>

    <div class="section-divider"></div>

    <h2 class="mb-4 mt-5">რა აზრი აქვთ ჩვენი კლიენტებს</h2>
    <div class="row">
        <div class="col-lg-6 reveal-left">
            <div class="testimonial">
                <p class="testimonial-text">"საუკეთესო მოტოციკლების მარკეტი რომელიც, ოდესმე გამომიყენებია."</p>
                <div class="testimonial-author">გიორგი ლომსაძე</div>
                <div class="testimonial-role">კლიენტი</div>
            </div>
        </div>
        <div class="col-lg-6 reveal-right">
            <div class="testimonial">
                <p class="testimonial-text">"დიდი არჩევანი და მისაღები ფასები. აბსოლუტურად რეკომენდირებული!"</p>
                <div class="testimonial-author">მარიამ მესხიშვილი</div>
                <div class="testimonial-role">კლიენტი</div>
            </div>
        </div>
    </div>
</div>

<!-- Test Ride Appointment Modal -->
<div class="modal fade" id="testRideModal" tabindex="-1" aria-labelledby="testRideLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="testRideLabel">მოტოციკლის გატესტვა</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("BookTestRide", "TestRide")" id="testRideForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="phoneNumber" class="form-label">ტელეფონის ნომერი *</label>
                        <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber" placeholder="+995 5XX XXX XXX" required />
                        <small class="form-text text-muted">გთხოვთ შეიყვანეთ ვალიდი ტელეფონის ნომერი. ჩვენი სპეციალისტი დაგიკავშირდება ამ ნომერზე.</small>
                    </div>
                    <div class="alert alert-info">
                        <h6 class="alert-heading">📋 შეკვეთის პირობები</h6>
                        <small>
                            <p>თქვენი მოთხოვნის შემდეგ, ჩვენი ხელმძღვანელი დაგიკავშირდება გაწერილი ტელეფონის ნომერზე, რათა:</p>
                            <ul class="mb-0">
                                <li>დაზუსტოს თქვენი საჭიროება და პირადი პრეფერენციები</li>
                                <li>მოამზადოს დეტალური ინფორმაცია ხელმისაწვდომი მოტოციკლებზე</li>
                                <li>შეთანხმოს გაუკეთებელი დღე და დრო ტესტ დრაივებისთვის</li>
                                <li>განმარტოს უსაფრთხოებისა და სიტყვის ხელმისაწვდომი პირობები</li>
                            </ul>
                        </small>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="agreeTerms" name="agreeTerms" required />
                        <label class="form-check-label" for="agreeTerms">
                            ✓ ვეთანხმები წამოთავებული პირობებს და დაგეთანხმებით რომ ჩვენი ხელმძღვანელი დაუკავშირდა
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">გაუქმება</button>
                    <button type="submit" class="btn btn-primary">დაჯავშვნა</button>
                </div>
            </form>
        </div>
    </div>
</div>


